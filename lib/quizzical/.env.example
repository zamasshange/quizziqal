# Copy to .env.local and replace placeholder values.
# Lines must NOT start with # — commented lines are ignored by Next.js.

# Required — Clerk authentication (https://dashboard.clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
CLERK_SECRET_KEY=sk_test_your_secret_key_here

# Optional — custom sign-in/up routes (defaults match /signin)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/signin
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/signin

# Site URL for SEO (canonical links, sitemap, Open Graph)
NEXT_PUBLIC_SITE_URL=https://quizzical.site

# Optional — AI wrong-answer generation (server-only)
# OPENROUTER_API_KEY=sk-or-v1-...
# OPENROUTER_MODEL=openai/gpt-4o-mini

# Optional — TMDB movie poster reveals
# TMDB_READ_TOKEN=

# Branded auth emails (see emails/clerk/README.md)
# RESEND_API_KEY=re_...
# AUTH_EMAIL_DOMAIN=quizzical.site
# CLERK_WEBHOOK_SIGNING_SECRET=whsec_...

# Optional — Supabase (leaderboards, activity feed, content history)
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
# SUPABASE_SERVICE_ROLE_KEY=sb_secret_...
